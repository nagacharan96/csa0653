#include <stdio.h>

int main() {
    int capital[] = {20, 30, 40, 50};
    int returns[] = {25, 40, 50, 70};
    int n = 4;
    int budget = 80;

    int dp[n + 1][budget + 1];

    for (int i = 0; i <= n; i++) {
        for (int w = 0; w <= budget; w++) {
            if (i == 0 || w == 0)
                dp[i][w] = 0;
            else if (capital[i - 1] <= w) {
                int include = returns[i - 1] + dp[i - 1][w - capital[i - 1]];
                int exclude = dp[i - 1][w];
                dp[i][w] = (include > exclude) ? include : exclude;
            } else {
                dp[i][w] = dp[i - 1][w];
            }
        }
    }

    printf("Maximum Expected Return = %d\n", dp[n][budget]);

    int w = budget;
    printf("Selected Investments: ");
    for (int i = n; i > 0; i--) {
        if (dp[i][w] != dp[i - 1][w]) {
            printf("%c ", 'A' + i - 1);
            w -= capital[i - 1];
        }
    }

    return 0;
}

