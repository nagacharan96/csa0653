profits = [25000, 40000, 50000, 65000]
costs = [20000, 30000, 40000, 50000]
budget = 100000
costs = [c // 1000 for c in costs]
budget = budget // 1000
n = len(profits)
dp = [[0]*(budget+1) for _ in range(n+1)
for i in range(1, n+1):
    for w in range(budget+1):
        if costs[i-1] <= w:
            dp[i][w] = max(
                dp[i-1][w],
                profits[i-1] + dp[i-1][w-costs[i-1]]
            )
        else:
            dp[i][w] = dp[i-1][w]
print("Maximum Profit =", dp[n][budget])

